{
  "name": "jcd-editor",
  "version": "0.0.0",
  "private": true,
  "description": "日本式の履歴書・職務経歴書を構造化データから生成する local-first ドキュメントエディタ",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
